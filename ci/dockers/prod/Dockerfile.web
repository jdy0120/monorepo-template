FROM node:20-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

FROM base AS builder
WORKDIR /app
COPY . .

ARG API_BASE_URL
ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_KAKAO_REST_API_KEY
ARG NEXT_PUBLIC_KAKAO_CLIENT_SECRET
ARG NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY
ARG NEXT_PUBLIC_KAKAO_REDIRECT_URI

ENV API_BASE_URL=${API_BASE_URL}
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_KAKAO_REST_API_KEY=${NEXT_PUBLIC_KAKAO_REST_API_KEY}
ENV NEXT_PUBLIC_KAKAO_CLIENT_SECRET=${NEXT_PUBLIC_KAKAO_CLIENT_SECRET}
ENV NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=${NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY}
ENV NEXT_PUBLIC_KAKAO_REDIRECT_URI=${NEXT_PUBLIC_KAKAO_REDIRECT_URI}

# Next.js 빌드를 위해 워크스페이스 의존성 모두 맵핑
RUN pnpm install --frozen-lockfile

# 웹만 빌드
RUN pnpm --filter database db:generate
RUN pnpm --filter web build

FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Next.js Standalone 결과물 복사
# Standalone 모드는 빌드된 코드와 node_modules 일부분을 모아서 내보냅니다.
COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static

EXPOSE 3000

ENV PORT=${WEB_PORT:-3001}
ENV HOSTNAME="0.0.0.0"

# Standalone은 apps/web/server.js를 떨굽니다.
CMD ["node", "apps/web/server.js"]
